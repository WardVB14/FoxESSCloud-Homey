{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.foxess.cloud",
  "version": "1.1.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "FoxESS Cloud"
  },
  "description": {
    "en": "Poll FoxESS Cloud and expose inverter values in Homey."
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "category": [
    "energy"
  ],
  "author": {
    "name": "Graham (v1), Ward (v1.1)",
    "email": "crazygrayv8@gmail.com;wardvanbeneden@gmail.com"
  },
  "brandColor": "#f47c20",
  "drivers": [
    {
      "name": {
        "en": "FoxESS Inverter"
      },
      "class": "other",
      "icon": "/drivers/foxess_inverter/assets/icon.svg",
      "images": {
        "small": "/drivers/foxess_inverter/assets/images/small.png",
        "large": "/drivers/foxess_inverter/assets/images/large.png",
        "xlarge": "/drivers/foxess_inverter/assets/images/xlarge.png"
      },
      "capabilities": [
        "measure_battery",
        "measure_battery_soc",
        "measure_battery_energy",
        "measure_power_meter_2",
        "measure_power",
        "measure_power_battery_charge",
        "measure_power_battery_discharge",
        "measure_power_feedin",
        "measure_power_grid_consumption",
        "button_refresh_data"
      ],
      "capabilitiesOptions": {
        "button_refresh_data": {
          "maintenanceAction": true,
          "title": {
            "en": "Refresh now"
          },
          "desc": {
            "en": "Request an immediate FoxESS poll."
          }
        }
      },
      "settings": [
        {
          "id": "api_key",
          "type": "password",
          "label": {
            "en": "FoxESS API key"
          },
          "hint": {
            "en": "The API key used to sign FoxESS Cloud requests."
          },
          "value": ""
        },
        {
          "id": "serial_number",
          "type": "text",
          "label": {
            "en": "Serial number"
          },
          "hint": {
            "en": "The FoxESS inverter serial number."
          },
          "value": ""
        },
        {
          "id": "domain",
          "type": "text",
          "label": {
            "en": "FoxESS API domain"
          },
          "hint": {
            "en": "Leave as default unless your FoxESS region uses a different endpoint."
          },
          "value": "https://www.foxesscloud.com"
        },
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Poll interval (seconds)"
          },
          "hint": {
            "en": "Minimum 60 seconds. Default 300."
          },
          "value": 300
        },
        {
          "id": "battery_capacity_kwh",
          "type": "number",
          "label": {
            "en": "Battery capacity (kWh)"
          },
          "hint": {
            "en": "Used to estimate remaining battery energy from state of charge."
          },
          "value": 5.12
        }
      ],
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "id": "foxess_inverter"
    }
  ],
  "capabilities": {
    "button_refresh_data": {
      "type": "boolean",
      "title": {
        "en": "Refresh data"
      },
      "getable": false,
      "setable": true,
      "uiComponent": "button"
    },
    "measure_battery_energy": {
      "type": "number",
      "title": {
        "en": "Battery Energy"
      },
      "units": {
        "en": "kWh"
      },
      "icon": "/assets/capabilities/battery_charging_state.svg",
      "insights": false,
      "decimals": 2,
      "min": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "measure_battery_soc": {
      "type": "number",
      "title": {
        "en": "Battery SoC"
      },
      "units": {
        "en": "%"
      },
      "icon": "/assets/capabilities/power.svg",
      "insights": true,
      "decimals": 0,
      "min": 0,
      "max": 100,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "measure_power": {
